# Copy to .env or export in your shell before running the Ktor server.
# Never commit real secrets.

# Public base URL of this server as reached by the device browser after Google OAuth.
# Android emulator API: http://10.0.2.2:8081  |  OAuth redirect host: http://localhost:8081 (adb reverse)
# Physical device on same LAN: http://YOUR_LAN_IP:8081
# Google Cloud "Authorized redirect URI" must be: ${XRMAIL_BASE_URL}/auth/callback
export XRMAIL_BASE_URL="http://localhost:8081"

export GOOGLE_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"
export GOOGLE_CLIENT_SECRET="your-client-secret"

# JWT signing secret (use a long random string in production)
export JWT_SECRET="change-me-in-production-use-env-var"

# Optional: OpenAI (voice) and Gemini (AI routes)
# export OPENAI_API_KEY=""
# export GEMINI_API_KEY=""
