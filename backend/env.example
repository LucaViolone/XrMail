# Copy to `backend/.env` before running `./gradlew :backend:run`.
# `backend/.env` is gitignored — never commit real secrets.
# Loader: `backend/build.gradle.kts` → OS env wins when both are set.
# Format: KEY=value (no `export` prefix — the Gradle loader reads raw KEY=value).

# Must match the Web OAuth client "Authorized redirect URI": ${XRMAIL_BASE_URL}/auth/callback
# Android emulator API can also reach the host on http://10.0.2.2:8081 — but OAuth
# redirects come from the device browser, which uses localhost via `adb reverse`
# (wired up in start.sh).
XRMAIL_BASE_URL=http://localhost:8081

GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT signing secret — generate a long random string for production.
JWT_SECRET="change-me-in-production-use-env-var"

# Optional — voice (/voice/transcribe) and AI routes (/ai/*).
# OPENAI_API_KEY=
# GEMINI_API_KEY=
